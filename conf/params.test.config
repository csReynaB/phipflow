/*
 * Minimal test run for one PHIPER group.
 * Run from this Nextflow project directory with:
 *   nextflow run main.nf -profile lisc -c conf/params.ibd_berlin_group_test.config -resume
 */
params {
    base_dir = '/lisc/data/scratch/ccr/CR_projects/phiper'

    project_name  = 'IBD-Berlin'
    metadata_file = 'IBD-Berlin_metadata.csv'

    // This becomes ACTIVE_GROUP='group_test' in 02-run_phiper_analysis.R
    group_cols = 'group_test'

    // If null, rendering uses the same value as group_cols.
    report_group_cols = null

    exist_file  = 'exist.csv'
    fold_file   = 'fold.csv'

    // If null, defaults to IBD-Berlin.parquet
    out_parquet = null

    all                    = 'FALSE'
    default_longitudinal   = 'FALSE'
    manual_comparison_file = 'NULL'
}

params {
    base_dir = '/lisc/data/scratch/ccr/CR_projects/phiper'

    project_name  = 'IBD-Berlin'
    metadata_file = 'IBD-Berlin_metadata.csv'

    exist_file  = 'exist.csv'
    fold_file   = 'fold.csv'

    // Optional. If null, defaults to <project_name>.parquet.
    out_parquet = null

    // Optional. These are the metadata group columns to analyze.
    // Each value is passed to 02-run_phiper_analysis.R as ACTIVE_GROUP.
    // If null, Nextflow will use all names listed in <project_name>/R/group_config.R group_definitions.
    group_cols = 'group_test,group_combined,group_IBD'

    // Optional override for 03-render_phiper_reports.R GROUP_COLS.
    // If null or omitted, reports use the same final values as group_cols.
    report_group_cols = null

    all                    = 'FALSE'
    default_longitudinal   = 'FALSE'
    manual_comparison_file = 'NULL'
}

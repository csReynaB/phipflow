manifest {
    name        = 'phipflow'
    description = 'Nextflow wrapper for PHIPER object creation, analysis and Quarto report rendering'
    mainScript  = 'main.nf'
}

params {
    /*
     * PHIPER project/data/results root.
     */
    base_dir = '/lisc/data/scratch/ccr/CR_projects/phiper'

    /*
     * Required at runtime or via a profile/config.
     */
    project_name  = null
    metadata_file = null

    /*
     * Analysis groups.
     */
    group_cols = null

    /*
     * Optional report groups.
     */
    report_group_cols = null

    /*
     * Input/output file names.
     */
    exist_file  = 'exist.csv'
    fold_file   = 'fold.csv'
    out_parquet = null

    /*
     * 01-create_phiper_object.R options.
     */
    sample_prefix = 'R'
    peptide_col   = 'peptide_name'
    replace_inf   = 'TRUE'

    /*
     * 02-run_phiper_analysis.R options.
     */
    all                    = 'FALSE'
    default_longitudinal   = 'FALSE'
    manual_comparison_file = 'NULL'
    force                  = 'false'

    /*
     * Runtime environment.
     *
     * use_modules = true:
     *   Load LiSC modules inside processes, e.g. R, Quarto, Pandoc.
     *
     * use_modules = false:
     *   Use tools from the container instead.
     */
    use_modules = true

    /*
     * Container image used by the apptainer profile.
     */
    container = null
}

process {
    executor = 'slurm'
    errorStrategy = 'terminate'
    maxRetries = 0

    withLabel: create_object {
        cpus = 1
        memory = '25 GB'
        time = '30 min'
    }

    withLabel: run_analysis {
        cpus = 20
        memory = '50 GB'
        time = '8 h'
    }

    withLabel: render_reports {
        cpus = 1
        memory = '10 GB'
        time = '30 min'
    }
}

executor {
    queueSize = 20
}

profiles {
    lisc {
        process.executor = 'slurm'
    }

    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = '/lisc/data/scratch/ccr/CR_projects/phiper/.apptainer_cache'

        params.use_modules = false
        params.container = "${projectDir}/containers/phipflow-r4.6.0-quarto1.9.37.sif"

        process.container = params.container
    }

    docker {
        process.executor = 'local'

        docker.enabled = true
        docker.fixOwnership = true

        params.use_modules = false
        params.container = 'ghcr.io/csreynab/phipflow-r4.6.0-quarto1.9.37:0.1.0'

        process.container = params.container

        /*
         * Needed because phipflow uses absolute paths for:
         *   - params.base_dir
         *   - projectDir
         */
        docker.runOptions = "-v ${params.base_dir}:${params.base_dir} -v ${projectDir}:${projectDir}"
    }

    /*
     * Default small test case.
     *
     * Run:
     *   nextflow run main.nf -profile lisc,apptainer,test -resume
     */
    test {
        params.project_name  = 'IBD-Berlin'
        params.metadata_file = 'IBD-Berlin_metadata.csv'
        params.group_cols    = 'pre-screening,group_IBD'
        params.report_group_cols = null
        params.out_parquet   = null

        params.all                    = 'FALSE'
        params.default_longitudinal   = 'FALSE'
        params.manual_comparison_file = 'NULL'
    }


    local_run {
        process.executor = 'local'

        process {
            withLabel: create_object {
                cpus = 1
                memory = '8 GB'
                time = '1 h'
            }

            withLabel: run_analysis {
                cpus = 8
                memory = '16 GB'
                time = '8 h'
            }

            withLabel: render_reports {
                cpus = 1
                memory = '8 GB'
                time = '1 h'
            }
        }
    }

}
